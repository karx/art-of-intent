{
  "name": "art-of-intent",
  "version": "2.0.1-alpha",
  "description": "Guide Arty the Haiku Bot to speak target words without using blacklisted words. A daily word puzzle game with AI interaction.",
  "main": "index.html",
  "type": "module",
  "scripts": {
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "test:analytics": "NODE_OPTIONS=--experimental-vm-modules jest tests/analytics.test.js",
    "test:legacy": "node tests/share-card-generator.test.js && node tests/leaderboard-card-generator.test.js",
    "test:share": "node tests/share-card-generator.test.js",
    "test:leaderboard": "node tests/leaderboard-card-generator.test.js",
    "generate:og": "node generate-og-image.js",
    "serve": "python3 -m http.server 8000",
    "dev": "python3 -m http.server 8000",
    "build": "cd frontend && npm run build",
    "cap:sync": "npx cap sync",
    "cap:open:ios": "npx cap open ios",
    "cap:open:android": "npx cap open android"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/karx/art-of-intent.git"
  },
  "keywords": [
    "word-game",
    "haiku",
    "ai-game",
    "puzzle",
    "daily-challenge",
    "prompt-engineering",
    "llm-game",
    "dos-aesthetic"
  ],
  "author": "karx",
  "license": "MIT",
  "homepage": "https://art-of-intent.netlify.app",
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/js/**/*.js",
      "!src/js/firebase-config.js"
    ],
    "coverageDirectory": "coverage",
    "verbose": true
  },
  "devDependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "@jest/globals": "^30.2.0",
    "jest": "^30.2.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "firebase-admin": "^13.5.0",
    "google-auth-library": "^10.4.2"
  }
}
